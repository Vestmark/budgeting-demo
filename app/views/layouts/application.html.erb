<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Budgeting" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <% if user_signed_in? %>
      <nav class="bg-white shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex">
              <div class="flex-shrink-0 flex items-center">
                <%= link_to "💰 Budgeting", root_path, class: "text-xl font-bold text-gray-900" %>
              </div>
              <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
                <%= link_to "Dashboard", root_path, class: "inline-flex items-center px-1 pt-1 text-sm font-medium #{current_page?(root_path) ? 'text-gray-900 border-b-2 border-indigo-500' : 'text-gray-500 hover:text-gray-700'}" %>
                <%= link_to "Transactions", transactions_path, class: "inline-flex items-center px-1 pt-1 text-sm font-medium #{current_page?(transactions_path) ? 'text-gray-900 border-b-2 border-indigo-500' : 'text-gray-500 hover:text-gray-700'}" %>
                <%= link_to "Budgets", budgets_path, class: "inline-flex items-center px-1 pt-1 text-sm font-medium #{current_page?(budgets_path) ? 'text-gray-900 border-b-2 border-indigo-500' : 'text-gray-500 hover:text-gray-700'}" %>
                <%= link_to "Income", income_sources_path, class: "inline-flex items-center px-1 pt-1 text-sm font-medium #{current_page?(income_sources_path) ? 'text-gray-900 border-b-2 border-indigo-500' : 'text-gray-500 hover:text-gray-700'}" %>
                <%= link_to "Categories", categories_path, class: "inline-flex items-center px-1 pt-1 text-sm font-medium #{current_page?(categories_path) ? 'text-gray-900 border-b-2 border-indigo-500' : 'text-gray-500 hover:text-gray-700'}" %>
              </div>
            </div>
            <div class="flex items-center">
              <span class="text-sm text-gray-700 mr-4"><%= current_user.email %></span>
              <%= button_to "Logout", logout_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-4">
        <div class="flex">
          <div class="ml-3">
            <p class="text-sm text-green-700"><%= notice %></p>
          </div>
        </div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-4">
        <div class="flex">
          <div class="ml-3">
            <p class="text-sm text-red-700"><%= alert %></p>
          </div>
        </div>
      </div>
    <% end %>

    <main class="<%= user_signed_in? ? 'max-w-7xl mx-auto py-6 sm:px-6 lg:px-8' : 'container mx-auto mt-28 px-5' %>">
      <%= yield %>
    </main>
  </body>
</html>
